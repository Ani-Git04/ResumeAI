{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{.venv/**,__pycache__/**,**/*.pyc,.pycache/**,tests/**,__tests__/**}"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}
